# Jarvis Desktop Assistant - Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ===========================================
# LLM Configuration (Required)
# ===========================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# Alternative: Anthropic API Key (if using Claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ===========================================
# Database Configuration (Optional)
# ===========================================

# PostgreSQL Connection (if using postgres instead of sqlite)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=jarvis
# POSTGRES_USER=jarvis
# POSTGRES_PASSWORD=your-secure-password

# ===========================================
# Logging Configuration (Optional)
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
JARVIS_LOG_LEVEL=INFO

# Optional: Custom log format
# JARVIS_LOG_FORMAT="%(asctime)s [%(levelname)s] %(name)s: %(message)s"

# ===========================================
# Application Configuration (Optional)
# ===========================================

# Path to config file (if not using default config/settings.toml)
# JARVIS_CONFIG=config/settings.toml
